<?xml version="1.0" encoding="utf-8"?>
<!--
  packages.config: the pre-PackageReference way to track NuGet dependencies.
  Every package listed by hand. Transitive dependencies also listed by hand.
  Versions pinned manually. Conflicts resolved by whoever had the most patience.
  In SDK-style projects this is replaced by <PackageReference> in the csproj.
  This file will not miss the era. The era was not fun.
-->
<packages>
  <!-- No external packages. JavaScriptSerializer lives in System.Web.Extensions,
       which ships with .NET 4.8. The framework includes everything needed to build
       this application and roughly seventeen other things you will never use.
       It ships complete. It ships heavy. It does not apologize. -->
</packages>
