<?xml version="1.0" encoding="utf-8"?>
<!--
  Web.config: the application's configuration file. In ASP.NET Core this is replaced by
  appsettings.json, which is replaced by environment variables, which are overridden by
  Azure App Configuration, which is managed by a YAML pipeline, which is reviewed by nobody.
  This is simpler. One file. You can read it. Treasure that.
-->
<configuration>
  <system.web>
    <compilation debug="true" targetFramework="4.8"/>
    <httpRuntime targetFramework="4.8"/>
  </system.web>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear/>
        <add value="index.html"/>
      </files>
    </defaultDocument>
    <!--
      .ashx handlers are registered natively by ASP.NET via SimpleHandlerFactory.
      No special handler entries needed here — unlike Web API, which required
      ExtensionlessUrlHandler to intercept routes without file extensions,
      which required removing and re-adding entries in the right order,
      which required understanding IIS pipeline configuration,
      which required reading documentation that was already two versions out of date.
      .ashx files just work. They are not glamorous. They work.
    -->
  </system.webServer>
</configuration>
